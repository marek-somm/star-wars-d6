{
  "name": "star-wars-d6-new",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "serve": "npm run dev",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint . --ext .js,.vue",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "pdfmake": "^0.2.20",
    "vue": "3.5.35"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "4.6.2",
    "eslint": "8.57.1",
    "eslint-plugin-vue": "9.33.0",
    "gh-pages": "6.1.1",
    "sass": "1.69.7",
    "vite": "4.5.14"
  },
  "eslintConfig": {
    "root": true,
    "ignorePatterns": [
      "dist/",
      "node_modules/"
    ],
    "env": {
      "browser": true,
      "node": true,
      "es2021": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "vue/multi-word-component-names": "off"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
